
@phdthesis{jacobson_structural_2025,
	type = {{PhD} {Thesis}},
	title = {Structural {Uncertainty} in {Energy} {Systems} {Models}: {Techniques} for {Mitigation} and {Impact} {Quantification}},
	url = {http://arks.princeton.edu/ark:/88435/dsp01cv43p128p},
	abstract = {Reliable, clean energy is critical for decarbonization and mitigation of the impacts of climate change. Energy systems models, which provide critical support for investment and operations of energy and electricity systems, are therefore necessary. Because all models are inherent simplifications of the systems they encapsulate, uncertainties will exist in results. These uncertainties may introduce inaccuracies of detriment to human welfare if recommendations are implemented. This thesis is an exploration of uncertainty in energy systems models: its sources, how it can be mitigated and quantified, and its policy-relevant impacts. We introduce a mathematical decomposition which greatly increases the scale of energy systems model that can be run. We show that our model allows for larger systems with higher spatial and temporal resolution than could be included under conventional modeling paradigms. We demonstrate that high resolution leads to more accurate models. We conclude that increased accuracy leads to lower system emissions, costs, and improved reliability. We create metrics that quantitatively bound inaccuracy and provide support on the resolutions of model that should be run to balance accuracy and computational limitations. The novel algorithm described in this thesis represents a paradigm shift for the types of resolution valuable to energy systems models and the accuracy these models are able to achieve moving forward.},
	school = {Princeton University},
	author = {Jacobson, Anna FL},
	year = {2025},
}

@phdthesis{hanna_leveraging_2025,
	type = {{PhD} {Thesis}},
	title = {Leveraging industry 4.0 enabled technologies to achieve {UN} sustainable development goals},
	url = {http://hdl.handle.net/10453/190581},
	abstract = {This thesis investigates how Industry 4.0 technologies can advance the United Nations Sustainable Development Goals (UN SDGs), with a particular focus on affordable and clean energy (SDG 7). This thesis develops novel frameworks and approaches for leveraging Artificial Intelligence (AI) and Blockchain (BC) to enhance energy efficiency, sustainability, and business transformation. The research addresses critical gaps in understanding how these smart technologies can be effectively implemented to achieve sustainability objectives, particularly in the context of family businesses as main drivers for sustainability, as they own over two-thirds of companies worldwide, and they account for over 70\% of the global GDP. This thesis offers a unique interdisciplinary perspective by examining the intersection of multiple Industry 4.0 technologies (AI and Blockchain) with various aspects of sustainable development, with a special focus on clean energy and renewable energy. This approach contributes to a more holistic understanding of how emerging technologies can be leveraged to address complex global challenges. The findings have significant practical implications for various stakeholders. For businesses, the research provides guidelines for implementing AI in clean energy applications, frameworks for managing missing data in energy consumption prediction, and strategies for blockchain adoption in energy-efficient supply chain management. For family businesses specifically, it offers roadmaps for technology integration and recommendations for balancing innovation with traditional business values. These insights support organisations in their journey toward sustainable development while maintaining their competitive advantage. This thesis bridges important gaps in the literature regarding the practical implementation of Industry 4.0 technologies for sustainable development, particularly in the context of energy management and family businesses. By demonstrating how Industry 4.0 technologies can be effectively leveraged to advance UN SDGs, this thesis contributes to the broader goal of achieving sustainable development while supporting business innovation and growth. The frameworks and approaches developed in this thesis can serve as foundations for future research and practical implementations in the rapidly evolving field of sustainable technology management.},
	school = {University of Technology Sydney},
	author = {Hanna, Bavly Samy Helmy},
	year = {2025},
}

@misc{law_decarbonization_2025,
	title = {Decarbonization pathways for liquid fuels: {A} multi-sector energy system perspective},
	url = {https://arxiv.org/abs/2511.19159},
	doi = {10.48550/arXiv.2511.19159},
	abstract = {Low-carbon liquid fuels play a key role in energy system decarbonization scenarios. This study uses a multi-sector capacity expansion model of the contiguous United States to examine fuels production in deeply decarbonized energy systems. Our analysis evaluates how the shares of biofuels, synthetic fuels, and fossil liquid fuels change under varying assumptions about resource constraints (biomass and CO2 sequestration availability), fuel demand distributions, and supply flexibility to produce different fuel products. Across all scenarios examined, biofuels provide a substantial share of liquid fuel supply, while synthetic fuels deploy only when biomass or CO2 sequestration is assumed to be more limited. Fossil liquid fuels remain in all scenarios examined, primarily driven by the extent to which their emissions can be offset with removals. Limiting biomass increases biogenic CO2 capture within biofuel pathways, while limiting sequestration availability increases the share of captured atmospheric (including biogenic) carbon directed toward utilization for synthetic fuel production. While varying assumptions about liquid fuel demand distributions and fuel product supply flexibility alter competition among individual fuel production technologies, broader energy system outcomes are robust to these assumptions. Biomass and CO2 sequestration availability are key drivers of energy system outcomes in deeply decarbonized energy systems.},
	author = {Law, Jun Wen and Mignone, Bryan K. and Mallapragada, Dharik S.},
	year = {2025},
	note = {\_eprint: 2511.19159},
}

@inproceedings{landsborough_database_2025,
	title = {Database {Deception} using {Large} {Language} {Models}},
	url = {https://faculty.nps.edu/ncrowe/WAITI_Data_based_deception_paper.pdf},
	abstract = {Cyberattackers often try to steal data in a cyberattack. Cyberdeception techniques such as supplying attackers with fake data (honeytokens) instead can interfere with their collection and exfiltration goals. This paper describes a design using a large language model to generate synthetic data from which defenders can create fictitious database records. We evaluated several models for this design using four SQLite databases, and tested the effectiveness of AI systems in identifying new data with two use cases: replacement of real records by fake records and shuffling fake and real records.},
	booktitle = {2025 {Annual} {Computer} {Security} {Applications} {Conference} {Workshops} ({ACSAC} {Workshops})},
	author = {Landsborough, Jason and Rowe, Neil C and Nguyen, Thuy D},
	year = {2025},
}

@techreport{palta_blending_2025,
	title = {Blending {Hydrogen} and {Natural} {Gas}: {A} road to nowhere for {New} {Jersey}},
	url = {https://www.switch.box/gh2nj},
	abstract = {This paper examines whether blending hydrogen into New Jersey’s natural gas distribution system is a viable strategy for decarbonizing the buildings sector, which accounts for roughly a quarter of the state’s greenhouse gas emissions. While New Jersey has committed to deep emissions reductions and plans to electrify most building heating by 2050, several gas utilities promote hydrogen–natural gas blending as a transitional or alternative pathway. We compare commonly proposed hydrogen blending scenarios with equivalent electrification using heat pumps and find that blending delivers minimal emissions reductions while requiring vastly more renewable electricity due to hydrogen’s low efficiency and high energy losses. A 20\% hydrogen blend would cut building emissions by only about 5\% and consume nearly eight times more electricity than heat pumps to achieve the same benefit, while a hypothetical 100\% hydrogen system would demand more clean electricity than the state’s entire net-zero economy and still fail to fully decarbonize buildings. We conclude that hydrogen blending is neither an effective interim solution nor a realistic pathway to full decarbonization, and instead risks prolonging reliance on fossil gas while diverting scarce renewable resources from far more effective electrification strategies.},
	institution = {SwitchBox},
	author = {Palta, Rina and Shron, Max and Smith, Alex and Velez, Juan-Pablo},
	year = {2025},
}

@article{schivley_process_2025,
	title = {Process and policy insights from an intercomparison of open electricity system capacity expansion models},
	volume = {2},
	url = {https://doi.org/10.1088/2753-3751/ade548},
	doi = {10.1088/2753-3751/ade548},
	abstract = {This study performs a detailed intercomparison of four open-source electricity capacity expansion models—Temoa, Switch, GenX, and USENSYS—to evaluate (1) how closely the results of these models align when inputs and configurations are harmonized, and (2) the degree to which varying model configurations affect outputs. We harmonize the inputs to each model using PowerGenome and use clearly defined scenarios (policy conditions) and configurations (model setup choices). This allows us to isolate how differences in model structure affect policy outcomes and investment decisions. Our framework allows each model to be tested on identical assumptions for policy, technology costs, and operational constraints, allowing us to focus on differences that arise from inherent model structures. Key findings highlight that, when harmonized, models produce very similar capacity portfolios under current policies and net-zero scenarios, with less than 1\% difference in system costs for most configurations. This agreement among models allows us to focus on how configuration choices affect model results. For instance, configurations with unit commitment constraints or economic retirement yield different investments and system costs compared to simpler configurations. Our findings underscore the importance of aligning input data and transparently defining scenarios and configurations to provide robust policy insights.},
	number = {4},
	journal = {Environmental Research: Energy},
	publisher = {IOP Publishing},
	author = {Schivley, Greg and Barone, Aurora and Blackhurst, Michael and Hidalgo-Gonzalez, Patricia and Jenkins, Jesse and Lugovoy, Oleg and Luo, Qian and Roberts, Michael J and Zheng, Rangrang and Wade, Cameron and Fripp, Matthias},
	month = nov,
	year = {2025},
	pages = {045006},
}

