@misc{craig_resolving_2026,
	title = {Resolving the {Mechanism} and {Value} of {Hydrogen}-{Based} {Seasonal} {Flexibility}},
	url = {https://www.researchsquare.com/article/rs-8875261/v1},
	doi = {10.21203/rs.3.rs-8875261/v1},
	abstract = {Studies disagree on whether hydrogen provides seasonal flexibility through power-to-hydrogen or power-to-hydrogen-to-power cycles. Studies also ignore large potential savings from retrofitting natural gas storage and pipelines for hydrogen, likely underestimating the value of hydrogen-based flexibility. We address these shortcomings using a sector-coupled capacity expansion model of the contiguous United States that incorporates retrofitting in a net-zero energy system. We find that power-to-hydrogen-to-power cycles are not economically viable in sector-coupled systems due to hydrogen\&\#039;s high commodity value. Instead, power-to-hydrogen provides most seasonal flexibility needs, enabled by decoupling of hydrogen production and consumption via retrofits. System cost savings from power-to-hydrogen seasonal flexibility exceed the combined value of its flexibility across all other timescales. Our results are robust to energy demand and technology uncertainties. These findings call for a demand-centric perspective of hydrogen-based seasonal flexibility in markets and policies, and for coordinated planning of transitioning natural gas to hydrogen infrastructure.},
	urldate = {2026-03-30},
	publisher = {Research Square},
	author = {Craig, Michael and Ai, Wei and Dowling, Jacqueline},
	month = mar,
	year = {2026},
	note = {ISSN: 2693-5015},
	file = {Full Text PDF:/home/thinky/snap/zotero-snap/common/Zotero/storage/W4C2L96C/Craig et al. - 2026 - Resolving the Mechanism and Value of Hydrogen-Based Seasonal Flexibility.pdf:application/pdf},
}

